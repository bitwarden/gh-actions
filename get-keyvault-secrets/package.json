{
  "name": "get-keyvault-secret",
  "version": "2.0.0",
  "description": "Github action for reading Azure Key Vault secrets",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --license licenses.txt",
    "postbuild": "node -e \"const fs=require('fs');fs.readdirSync('dist').filter(f=>f.endsWith('.js')).forEach(f=>{const p='dist/'+f;fs.writeFileSync(p,fs.readFileSync(p,'utf8').replace(/\\r\\n/g,'\\n'))})\""
  },
  "license": "ISC",
  "devDependencies": {
    "@types/node": "25.5.0",
    "@vercel/ncc": "0.38.4",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "@actions/core": "3.0.0",
    "@azure/identity": "4.13.1",
    "@azure/keyvault-secrets": "4.10.0"
  },
  "repository": {
    "type": "git",
    "url": "(https://github.com/bitwarden/gh-actions.git)"
  }
}
